
                ifndef _CONST_MEMORY_MAP_PAGE_7_
                define _CONST_MEMORY_MAP_PAGE_7_
                
                ;   +-------+------------------------------------------+-------+
                ;   | #С000 |                             ShadowScreen | #1B00 |
                ;   +-------+------------------------------------------+-------+
                ;   | #DB00 |                           CursorStorageA | #0100 | ; буфер сохранения фона под курсором
                ;   +-------+------------------------------------------+-------+
                ;   | #DC00 |                           СursorStorageB | #0100 | ; буфер сохранения фона под курсором (дополнительный см PipelineHexagons.MemcpyScreen)
                ;   +-------+------------------------------------------+-------+
                ;   | #DD00 |                          BitScanLsbTable | #0100 | ; таблица для поиска первого установленного бита
                ;   +-------+------------------------------------------+-------+
                ;   | #DE00 |                               EventArray | #0100 | ; массив событий
                ;   +-------+------------------------------------------+-------+
                ;   | #DF00 |                         HexagonAnalysis: | #0100 | ; таблица для работы функции - анализ обновления гексагонов
                ;   | #DF00 |                          - Div6Table22   | #0016 | ; таблица деления 0-21 на 6
                ;   | #DF16 |                          - ScreenBlock   | #0010 | ; буфер обновления экранных блоков
                ;   | #DF50 |                          - ScrBlockTable | #00B0 | ; таблица номера экранного блока (с 1 по 22 строку включительно) с высотой гексагона
                ;   +-------+------------------------------------------+-------+
                ;   | #E500 |                                 свободно | #1000 | ; свободно
                ;   +-------+------------------------------------------+-------+
                ;   | #F000 |                             SharedScreen | #1000 | ; общая память для кода
                ;   +-------+------------------------------------------+-------+

                module Page
SharedScreen    EQU PAGE_7
BitScanLsbTable EQU PAGE_7
Div6Table22     EQU PAGE_7
ScrBlockTable   EQU PAGE_7
                endmodule

                module Size
BitScanLsbTable EQU #0100                                                       ; размер таблицы для поиска первого установленного бита
EventArray      EQU #0100                                                       ; размер массива событий
Div6Table22     EQU SCR_WORLD_SIZE_X                                            ; размер таблицы деления 0-21 на 6
ScrBlockTable   EQU #00B0                                                       ; размер таблицы номера экранного блока (с 1 по 22 строку включительно) с высотой гексагона
CursorStorage   EQU #0100                                                       ; размер буфера сохранения фона под курсором
SharedScreen    EQU #1000                                                       ; размер общей памяти для кода
                endmodule

                module Adr
CursorStorageA  EQU #DB00                                                       ; адрес буфера сохранения фона под курсором
CursorStorageB  EQU #DC00                                                       ; адрес буфера сохранения фона под курсором (дополнительный см PipelineHexagons.MemcpyScreen)
BitScanLsbTable EQU #DD00                                                       ; адрес таблицы для поиска первого установленного бита
EventArray      EQU #DE00                                                       ; адрес массива событий
Div6Table22     EQU #DF00                                                       ; адрес раположения таблица деления 0-21 на 6
ScreenBlock     EQU #DF16                                                       ; адрес раположения буфера обновления экранных блоков
ScrBlockTable   EQU #DF50                                                       ; адрес раположения таблицы номера экранного блока (с 1 по 22 строку включительно) с высотой гексагона
SharedScreen    EQU #F000                                                       ; адрес общей памяти для кода
                endmodule

                endif ; ~_CONST_MEMORY_MAP_PAGE_7_
