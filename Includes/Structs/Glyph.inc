
                ifndef _STRUCTS_GLYPH_
                define _STRUCTS_GLYPH_

                struct FGlyphHeader                                             ; описание глифа                                                    [3 байта]
Count           DB #00                                                          ; количество точек в глифе                                          [1 байта]
Advance         DB #00                                                          ; насколько сдвинуть курсор после буквы (шиирина буквы + пробел)    [1 байта]
Baseline        DB #00                                                          ; базовая линия глифа                                               [1 байта]
                                                                                ; необходима, чтобы буквы разной высоты располагались
                                                                                ; правильно относительно одной строки
Points                                                                          ; массив точек, где старший полубайт это Y, а младший X
                ends

                endif ; ~_STRUCTS_GLYPH_
