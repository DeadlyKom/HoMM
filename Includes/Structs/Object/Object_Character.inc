
                ifndef _STRUCT_OBJECT_CHARACTER_
                define _STRUCT_OBJECT_CHARACTER_

                struct FObjectCharacter                                         ; базовый объект персонажа на карте                         [31 байт]
Super           FObject                                                         ; базовый класс объекта                                     [14 байт]
; -----------------------------------------
;   FObjectCharacter.Super.Sprite
;      7    6    5    4    3    2    1    0
;   +----+----+----+----+----+----+----+----+
;   | .. | AS | D2 | D1 | D0 | A2 | A1 | A0 |
;   +----+----+----+----+----+----+----+----+
;
;   AS      [6]     - состояние анимации
;                       0 - бездействие/поворот
;                       1 - перемещение
;   В2-В0   [5..3]  - направление спрайта
;                       000 - вверх
;                       001 - вверх-вправо
;                       010 - вправо
;                       011 - вниз-вправо
;                       100 - вниз
;                       101 - вниз-влево
;                       110 - влево
;                       111 - вверх-влево
;   A2-A0   [2..0]  - индекс анимации спрайта
; -----------------------------------------
CharacterID     DB #00                                                          ; идентификатор владельца (структура FCharacter)            [1 байт]
PathID          DB #00                                                          ; текущий воспроизводимый индекс в массиве пути             [1 байт]
WayPointID      DB #00                                                          ; текущий воспроизводимый индекс WayPoint                   [1 байт]
; -----------------------------------------
;   поля состояния DDA являются беззнаковыми 16-битными значениями:
;   MajorRemaining - количество оставшихся четвертьпиксельных шагов по главной оси
;   MajorLength    - полная длина сегмента по главной оси в четвертях пикселя
;   MinorLength    - полная длина сегмента по вторичной оси в четвертях пикселя
;   LineError      - накопленная ошибка DDA в диапазоне [0..MajorLength - 1] при ненулевой длине
; -----------------------------------------
MajorRemaining  FValue                                                          ; оставшееся число шагов по главной оси DDA                  [2 байта]
MajorLength     FValue                                                          ; длина сегмента по главной оси DDA                          [2 байта]
MinorLength     FValue                                                          ; длина сегмента по вторичной оси DDA                        [2 байта]
LineError       FValue                                                          ; накопленная ошибка DDA                                     [2 байта]
; -----------------------------------------
;   FObjectCharacter.MovementFlags
;      7    6    5    4    3    2    1    0
;   +----+----+----+----+----+----+----+----+
;   | .. | .. | .. | .. | .. | YN | XN | MY |
;   +----+----+----+----+----+----+----+----+
;
;   MY      [0]     - флаг, главная ось DDA
;                       0 - X,  1 - Y
;   XN      [1]     - флаг, направление шага по горизонтали
;                       0 - вправо, 1 - влево
;   YN      [2]     - флаг, направление шага по вертикали
;                       0 - вниз,   1 - вверх
; -----------------------------------------
MovementFlags   DB #00                                                          ; ось и направления движения DDA                             [1 байт]
; -----------------------------------------
;   EffectiveStepCost является кэшем итоговой стоимости DDA-шага для текущего участка маршрута.
;   HextileID не хранится в объекте постоянно, т.к. его можно получить по координатам
;   при пересчёте стоимости.
;
;   EffectiveStepCost = ceil(SurfaceStepCost * PathfindingScale / 16)
;
;   При добавлении нескольких 4.4-множителей каждый новый множитель должен
;   добавлять своё деление на 16 с округлением вверх
;
;   Пересчёт требуется только при изменении аргументов формулы:
;     - объект перешёл в другой гекс;
;     - изменились навыки, экипировка, бафы или дебафы персонажа;
;     - изменились внешние условия, влияющие на проходимость.
; -----------------------------------------
EffectiveStepCost DB #00                                                        ; итоговая стоимость одного DDA-шага                         [1 байт]
; -----------------------------------------
;   бюджеты движения являются беззнаковыми 16-битными значениями в единицах движения:
;   MovementBudget  - доступные единицы для оплаты DDA-шагов;
;   MovementPending - единицы текущего временного пакета, ещё не переданные движению;
;   при переполнении значения насыщаются до #FFFF
; -----------------------------------------
MovementBudget  FValue                                                          ; доступный бюджет движения                                   [2 байта]
MovementPending FValue                                                          ; нераспределённый бюджет текущего временного пакета          [2 байта]
                ends

                endif ; ~_STRUCT_OBJECT_CHARACTER_
