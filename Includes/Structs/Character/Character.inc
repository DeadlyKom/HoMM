
                ifndef _STRUCTS_CHARACTER_
                define _STRUCTS_CHARACTER_
;-------------------------------------------------------------------------------
                struct FCharacterSkills                                         ; навыки персонажа                                                  [байт]
PrimarySkill    FPrimarySkill                                                   ; основные навыки                                                   [4 байта]
SecondarySkill  FSecondarySkill                                                 ; вторичные навыки                                                  [байт]
                ends
;-------------------------------------------------------------------------------
                struct FCharacterSettings                                       ; настройки персонажа участника                                     [байт]
                                                                                ; необходим для инициализации участника,
                                                                                ; настраивается пользователем в главном меню
Class           DB #00                                                          ; класс персонажа                                                   [1 байт]
                                                                                ; Note: 
                                                                                ;   влияет на вероятность выподания вторичных навыков
Skils           FCharacterSkills                                                ; навыки персонажа                                                  [байт]
                ends
;-------------------------------------------------------------------------------
                struct FCharacter                                               ; персонаж "аватар", за которого играет человек или ИИ              [32 байта]
Class           DB #00                                                          ; класс персонажа                                                   [1 байт]
                                                                                ; Note: 
                                                                                ;   влияет на вероятность выподания вторичных навыков
ParticipantID   DB #00                                                          ; идентификатор владельца, указатель на структуру FParticipant      [1 байт]
Skils           FCharacterSkills                                                ; навыки персонажа                                                  [байт]
CombatStates    FCombatStates                                                   ; боевые состояния                                                  [2 байта]
Equipment       FCharacterEquipment                                             ; экипировка персонажа                                              [10 байт]
ObjectID        DB #00                                                          ; идентификатор объекта, к которому привязан                        [1 байт]
                                                                                ; Note: 
                                                                                ;   при перемещении структуры FObjectCharacter в массиве, необходимо
                                                                                ;   обновлять идентификатор объекта
                ends
;-------------------------------------------------------------------------------
                endif ; ~_STRUCTS_CHARACTER_
