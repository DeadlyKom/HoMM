
                ifndef _STRUCTS_WORLD_TIME_
                define _STRUCTS_WORLD_TIME_

                struct FWorldTime                                               ; структура, описывающая игровое календарное время
WorldTick       FValue                                                          ; остаток "мировых тиков" до следующего часа
Hour            DB #00                                                          ; часы,                                 [#00..#23]  BCD
Day             DB #00                                                          ; день месяца,                          [#01..#31]  BCD
Month           DB #00                                                          ; месяц,                                [0..11]     число, 0 = январь
Years           DW #0000                                                        ; год,                                  [0..65535]  число
                ends

                struct FWorldTimeControl                                        ; структура управления течением игрового времени
AdvanceLeft     FValue                                                          ; остаток "мировых тиков" текущего запроса
PlaybackScale   DB #00                                                          ; масштаб пакета времени, распределяемого в текущей cadence-эпохе
; -----------------------------------------
;      7    6    5    4    3    2    1    0
;   +----+----+----+----+----+----+----+----+
;   | .. | .. | .. | .. | .. | .. | .. | EA |
;   +----+----+----+----+----+----+----+----+
;
;   EA      [0]         - флаг, активной фазы "мирового тика" в текущей cadence-эпохе
; -----------------------------------------
Flags           DB #00                                                          ; флаги управления текущей cadence-эпохой
                ends

                endif ; ~_STRUCTS_WORLD_TIME_
